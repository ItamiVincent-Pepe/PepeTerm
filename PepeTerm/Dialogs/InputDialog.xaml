<Window x:Class="PepeTerm.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🐸 PepeTerm" Width="350" Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource ToolbarBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LabelBlock" Grid.Row="0" Text="Введите значение:"
                   Foreground="White" Margin="0,0,0,10"/>

        <TextBox x:Name="InputBox" Grid.Row="1"
                 Background="#3C3C3C" Foreground="White"
                 BorderBrush="#555555" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK" Width="70"
                    Background="#0E639C" Foreground="White"
                    Click="OkButton_Click"/>
            <Button Content="Отмена" Width="70"
                    Background="#3C3C3C" Foreground="White"
                    Margin="10,0,0,0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>