<Window x:Class="PepeTerm.Dialogs.SerialSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ Настройки COM-порта"
        Width="340" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource ToolbarBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Скорость (бод) -->
        <TextBlock Grid.Row="0" Text="Скорость (бод):"
                   Foreground="#CCCCCC" Margin="0,8,0,4"/>
        <ComboBox x:Name="BaudRateBox" Grid.Row="1"
                  Style="{StaticResource DarkComboBoxStyle}"
                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                  Margin="0,0,0,10"/>

        <!-- Биты данных -->
        <TextBlock Grid.Row="2" Text="Биты данных:"
                   Foreground="#CCCCCC" Margin="0,8,0,4"/>
        <ComboBox x:Name="DataBitsBox" Grid.Row="3"
                  Style="{StaticResource DarkComboBoxStyle}"
                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                  Margin="0,0,0,10"/>

        <!-- Чётность -->
        <TextBlock Grid.Row="4" Text="Чётность:"
                   Foreground="#CCCCCC" Margin="0,8,0,4"/>
        <ComboBox x:Name="ParityBox" Grid.Row="5"
                  Style="{StaticResource DarkComboBoxStyle}"
                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                  Margin="0,0,0,10"/>

        <!-- Стоп-биты -->
        <TextBlock Grid.Row="6" Text="Стоп-биты:"
                   Foreground="#CCCCCC" Margin="0,8,0,4"/>
        <ComboBox x:Name="StopBitsBox" Grid.Row="7"
                  Style="{StaticResource DarkComboBoxStyle}"
                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                  Margin="0,0,0,10"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="70"
                    Style="{StaticResource PrimaryButton}"
                    Click="OkButton_Click"/>
            <Button Content="Отмена" Width="70"
                    Style="{StaticResource SecondaryButton}"
                    Margin="10,0,0,0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>