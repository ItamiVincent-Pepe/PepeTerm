<Window x:Class="PepeTerm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🐸 PepeTerm" Height="680" Width="1546"
        Background="{StaticResource BackgroundColor}"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковая панель с TreeView -->
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0" Grid.RowSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📋 Сохранённые" Style="{StaticResource LabelStyle}"
                           FontSize="14" FontWeight="Bold" Margin="10,10,10,5"/>

                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="5,0,5,5">
                    <Button Content="📁 +" ToolTip="Добавить папку"
                            Style="{StaticResource SecondaryButton}"
                            Width="40" Height="26" FontSize="14" Padding="0"
                            Click="AddFolder_Click"/>
                    <Button Content="🗑" ToolTip="Удалить выбранное"
                            Style="{StaticResource SecondaryButton}"
                            Width="40" Height="26" FontSize="14" Padding="0" Margin="5,0,0,0"
                            Click="DeleteSelected_Click"/>
                </StackPanel>

                <TreeView x:Name="TreeView" Grid.Row="2"
                          Background="{StaticResource PanelBrush}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          BorderBrush="Transparent" Margin="5,0,5,5"
                          MouseDoubleClick="TreeView_MouseDoubleClick"/>
            </Grid>
        </Border>
        
        

        <!-- Основная область -->
        <Grid Grid.Column="1" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource ToolbarBrush}" Padding="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Протокол:" Style="{StaticResource LabelStyle}"/>
                    <RadioButton x:Name="RadioTelnet" Content="Telnet"
                                 IsChecked="True" Margin="0,0,8,0"
                                 Style="{StaticResource RadioStyle}"
                                 Checked="Protocol_Changed"/>
                    <RadioButton x:Name="RadioSSH" Content="SSH"
                                 Margin="0,0,8,0"
                                 Style="{StaticResource RadioStyle}"
                                 Checked="Protocol_Changed"/>
                    <RadioButton x:Name="RadioSerial" Content="Serial"
                                 Margin="0,0,10,0"
                                 Style="{StaticResource RadioStyle}"
                                 Checked="Protocol_Changed"/>

                    <TextBlock Text="Имя:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="NameBox" Width="140" Margin="0,0,10,0" Style="{StaticResource InputStyle}"/>

                    <TextBlock x:Name="HostLabel" Text="Хост:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="HostBox" Width="140" Margin="0,0,10,0" Style="{StaticResource InputStyle}" Text="192.168.1.1"/>

                    <TextBlock x:Name="PortLabel" Text="Порт:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="PortBox" Width="60" Margin="0,0,10,0" Style="{StaticResource InputStyle}" Text="23"/>

                    <TextBlock x:Name="LoginLabel" Text="Логин:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="UsernameBox" Width="100" Margin="0,0,10,0" Style="{StaticResource InputStyle}"/>

                    <TextBlock x:Name="PasswordLabel" Text="Пароль:" Style="{StaticResource LabelStyle}"/>
                    <PasswordBox x:Name="PasswordBox" Width="100" Margin="0,0,10,0" Style="{StaticResource PasswordStyle}"/>

                    <Button x:Name="SerialSettingsBtn" Content="⚙️"
                            ToolTip="Настройки COM-порта" Visibility="Collapsed"
                            Width="30" Height="26" Margin="0,0,10,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="SerialSettings_Click"/>

                    <Button x:Name="ConnectButton" Content="⚡ Подключиться"
                            Width="120" Style="{StaticResource PrimaryButton}"
                            Click="ConnectButton_Click"/>
                    <Button x:Name="SaveButton" Content="💾 Сохранить"
                            Width="100" Margin="10,0,0,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Border>

            <TabControl x:Name="SessionsTabControl" Grid.Row="1"
                        Background="{StaticResource BackgroundColor}"
                        BorderBrush="{StaticResource BorderBrush}"/>
        </Grid>
    </Grid>
</Window>